{
  // ── Serilog ─────────────────────────────────────────────────────────────────
  // Information level gives request/tool logs in the interactive CLI without noise.
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft":                             "Warning",
        "Microsoft.EntityFrameworkCore":         "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },

  // ── Storage ──────────────────────────────────────────────────────────────────
  "ConnectionStrings": {
    "Default": "Data Source=toolengine-cli.db"
  },
  "Database": {
    // sqlite | postgresql | sqlserver
    "Provider": "sqlite"
  },
  "Cache": {
    // memory | redis
    // CLI uses in-process memory cache — no Redis required for local dev.
    "Provider": "memory"
  },

  // ── Pipeline guards ───────────────────────────────────────────────────────────
  "LoopDetection": {
    // Max times the same tool can be called within a single correlation before
    // the circuit opens with 429 AGENT_LOOP_DETECTED.
    "MaxCallsPerCorrelation": 5
  },

  // ── Approval ──────────────────────────────────────────────────────────────────
  // CLI uses ConsoleApprovalGate (Y/N prompt). Channel config is not used,
  // but the section is required by the infrastructure DI registration.
  "Approval": {
    "DefaultChannel":         "Dashboard",
    "ApprovalTimeoutMinutes": 30,
    "BaseUrl":                "http://localhost:5174"
  },

  // ── LLM agent layer ───────────────────────────────────────────────────────────
  "Llm": {
    // "ollama" is the CLI default — zero API cost for local developer use.
    // Set ANTHROPIC_API_KEY or OPENAI_API_KEY and change DefaultProvider
    // to "anthropic" / "openai" for cloud-backed CLI sessions.
    "DefaultProvider": "anthropic",

    "Routing": {
      // FallbackChain lists PROVIDER KEYS (not model names) tried in order
      // when the primary provider fails. Omit cloud providers here so the
      // CLI never silently incurs API cost on a local-model failure.
      "FallbackChain": []
    },

    "Budget": {
      // MaxTokensPerRequest: ceiling on LLM output tokens per iteration.
      // Tool-selection outputs are ~100–500 tokens; summaries ~300–800 tokens.
      // 1024 is sufficient for CLI single-turn queries and avoids runaway cost.
      "MaxTokensPerRequest": 1024,

      // MaxTokensPerSession: cumulative token ceiling across all iterations.
      // CLI sessions are single developer queries — 4 096 covers 3–4 exchanges.
      "MaxTokensPerSession": 4096,

      // MaxIterations: agentic loop hard stop.
      // CLI flow: understand → select → execute → summarise = 3 LLM calls max.
      "MaxIterations": 3
    },

    "Providers": {
      // ── Ollama (local, zero cost) ─────────────────────────────────────────
      // Requires Ollama running: https://ollama.ai
      // Pull model: ollama pull llama3.1:8b
      "ollama": {
        "BaseUrl": "http://localhost:11434",
        // llama3.1:8b — best-supported Ollama model for tool-use (OpenAI-compat format).
        // Alternative: qwen2.5:7b — slightly better tool-calling but less widely pulled.
        "Model": "llama3.1:8b",
        // 1 024 output tokens: matches MaxTokensPerRequest above.
        // Local 8B inference is ~20–120 tok/s — higher limits add latency.
        "MaxTokens": 1024,
        // Local models have variable cold-start latency. 120 s covers slow hardware.
        "TimeoutSeconds": 120
      },

      // ── Anthropic (cloud — requires ANTHROPIC_API_KEY env var) ───────────
      "anthropic": {
        // claude-sonnet-4-5: fastest Sonnet tier. Accurate tool selection at ~$3/$15
        // per 1 M input/output tokens. Haiku would be cheaper but less reliable for
        // multi-step tool routing.
        "Model": "claude-haiku-4-5",
        "ApiKeyEnvVar": "ANTHROPIC_API_KEY",
        "MaxTokens": 1024,
        "TimeoutSeconds": 30
      },

      // ── OpenAI (cloud — requires OPENAI_API_KEY env var) ─────────────────
      "openai": {
        // gpt-4o-mini: cheaper than gpt-4o, strong tool-use accuracy for simple
        // CLI queries. Switch to "gpt-4o" for complex multi-step tasks.
        "Model": "gpt-4o-mini",
        "ApiKeyEnvVar": "OPENAI_API_KEY",
        "MaxTokens": 1024,
        "TimeoutSeconds": 30
      }
    }
  }
}
