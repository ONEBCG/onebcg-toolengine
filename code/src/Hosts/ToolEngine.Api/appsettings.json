{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Jwt": {
    "Issuer":   "toolengine",
    "Audience": "toolengine-clients",
    "Secret":   "REPLACE_WITH_ENV_VAR_OR_SECRET_MANAGER"
  },
  "AllowedHosts": "*"
}
