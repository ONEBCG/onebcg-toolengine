{
  // ── Serilog ──────────────────────────────────────────────────────────────────
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft":                                       "Warning",
        "Microsoft.EntityFrameworkCore":                   "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command":  "Warning"
      }
    }
  },

  // ── JWT authentication ────────────────────────────────────────────────────────
  // Secret must be ≥ 32 bytes (256-bit HMAC-SHA256). NEVER commit a real value.
  // Production: set JWT__SECRET via environment variable or secret manager.
  "Jwt": {
    "Issuer":   "toolengine",
    "Audience": "toolengine-clients",
    "Secret":   "REPLACE_WITH_ENV_VAR_OR_SECRET_MANAGER"
  },

  // ── Database (F1) ─────────────────────────────────────────────────────────────
  // Provider: "sqlite" (dev default) | "postgresql" | "sqlserver"
  // Connection string is read from ConnectionStrings:Default.
  // Production: set DATABASE__PROVIDER and CONNECTIONSTRINGS__DEFAULT via env vars.
  "Database": {
    "Provider": "sqlite"
  },
  "ConnectionStrings": {
    "Default": "REPLACE_WITH_ENV_VAR",
    "Redis":   "REPLACE_WITH_ENV_VAR"
  },

  // ── Cache (F3) ────────────────────────────────────────────────────────────────
  // Provider: "memory" (single-node dev) | "redis" (production multi-pod)
  // Redis requires ConnectionStrings:Redis and registers DistributedCacheProvider.
  "Cache": {
    "Provider": "memory"
  },

  // ── Pipeline guards ───────────────────────────────────────────────────────────
  "LoopDetection": {
    // Max calls per (correlationId, tool) before 429 AGENT_LOOP_DETECTED.
    // Keep low to protect against runaway agent loops in production.
    "MaxCallsPerCorrelation": 10
  },

  // ── Approval engine ───────────────────────────────────────────────────────────
  // BaseUrl MUST be https:// in non-development (startup validation enforces this).
  // WebhookUrl is optional; required only if any tenant uses the Webhook channel.
  "Approval": {
    "DefaultChannel":         "Dashboard",
    "ApprovalTimeoutMinutes": 60,
    "BaseUrl":                "https://REPLACE_WITH_PRODUCTION_DOMAIN",
    "WebhookUrl":             null,
    "TenantChannelOverrides": {}
  },

  // ── OpenTelemetry (G1 / G2) ───────────────────────────────────────────────────
  // Set Otlp:Endpoint to export traces and metrics to your collector.
  // Example: "http://otel-collector:4317"
  // When absent: instrumentation is active but not exported (useful with local Jaeger).
  "Otlp": {
    "Endpoint": null
  },

  // ── LLM agent layer (Phase L) ─────────────────────────────────────────────────
  "Llm": {
    // DefaultProvider: the provider used when neither a tool attribute nor the
    // tenant configuration specifies one.
    // Production recommendation: "anthropic" (claude-sonnet-4-5 — best tool-use
    // accuracy-to-cost ratio in 2026 for consulting workloads).
    "DefaultProvider": "anthropic",

    "Routing": {
      // FallbackChain: PROVIDER KEYS tried in order when the primary provider
      // returns a non-200 or times out. Ollama last — only available if self-hosted.
      "FallbackChain": [ "openai", "ollama" ]
    },

    // ── Scope guard ───────────────────────────────────────────────────────────
    // Pre-flight scope classification: a lightweight LLM call runs BEFORE the
    // main orchestration loop to determine whether the user's request is within
    // the domain of available tools.
    //
    // Why this works where system-prompt-only approaches don't:
    //   Capable LLMs (Claude, GPT-4o) override system prompt scope restrictions
    //   using their training instinct to be helpful. A dedicated classification
    //   call returns structured JSON the orchestrator acts on deterministically.
    //
    // Outcomes:
    //   Fully out of scope  → friendly refusal returned; no tool loop entered.
    //   Mixed request       → only in-scope portion forwarded; out-of-scope
    //                         parts noted in the final reply.
    //   Fully in scope      → request passes through unchanged.
    //   Classification fail → fail-open (request passes; system prompt applies).
    //
    // Set Enabled=false ONLY in fully-trusted dev environments where free-form
    // LLM responses are acceptable regardless of tool scope.
    "ScopeGuard": {
      "Enabled": true
    },

    // ── Tool guard ────────────────────────────────────────────────────────────
    // Controls which tools the LLM agent may see and invoke.
    // Enforced at two points: (1) pre-LLM schema filter — blocked tools are
    // invisible to the model; (2) post-selection validation — defence in depth
    // against prompt injection where the LLM is tricked into "calling" a tool
    // it was never shown.
    //
    // Pattern syntax:
    //   "math.calculate"  — exact full name (case-insensitive)
    //   "math.*"          — all tools in the math namespace
    //   "*"               — all tools (global wildcard)
    //
    // Precedence: DeniedTools overrides AllowedTools.
    //   A tool present in both lists is always blocked.
    //   Empty AllowedTools = all tools permitted (only DeniedTools active).
    //   Empty DeniedTools  = nothing explicitly denied (only AllowedTools active).
    //
    // Production guidance:
    //   - Deny sensitive namespaces (hr.*, finance.*, admin.*) by default.
    //   - Use AllowedTools to whitelist when deploying a scoped agent (e.g. a
    //     customer support bot that should only access support.* tools).
    //   - Set Enabled=false ONLY in fully-trusted local development environments.
    "ToolGuard": {
      "Enabled": true,
      // Empty AllowedTools = no allowlist restriction. All tools pass unless denied.
      // To restrict to a specific set: [ "math.*", "weather.current" ]
      "AllowedTools": [],
      // Deny-by-default for sensitive namespaces. Extend as needed per deployment.
      "DeniedTools": []
    },

    "Budget": {
      // MaxTokensPerRequest: advisory ceiling on output tokens per LLM call.
      // Tool-selection outputs are 100–500 tokens; summaries 300–800 tokens.
      // 2 048 is generous headroom without paying for unused capacity.
      "MaxTokensPerRequest": 2048,

      // MaxTokensPerSession: cumulative token circuit-breaker (checked before each LLM call).
      // Counts ALL LLM calls in the session: scope classification pre-flight + tool-selection
      // + grounded-summary. A tool-invoking turn costs ~2 500–3 500 tokens as history grows.
      // 32 768 supports ~8–10 multi-turn exchanges with tool invocations.
      // Reduce per-tenant for cost-sensitive workloads via tenant config overrides.
      "MaxTokensPerSession": 32768,

      // MaxIterations: hard stop on the agentic loop. Typical flow:
      //   user query → tool selection → execution → summary = 3 LLM calls.
      // 5 allows one disambiguation round + one retry without runaway risk.
      "MaxIterations": 5
    },

    "Providers": {
      // ── Anthropic ─────────────────────────────────────────────────────────
      // claude-sonnet-4-5: best cost-to-accuracy for tool routing in 2026.
      // Pricing: ~$3 / $15 per 1 M input / output tokens.
      // Opus is overkill for tool selection; Haiku risks lower routing accuracy.
      "anthropic": {
        "Model":          "claude-sonnet-4-5",
        "ApiKeyEnvVar":   "ANTHROPIC_API_KEY",
        "MaxTokens":      2048,
        // 30 s covers p99 latency for Sonnet. Increase to 45 for complex prompts.
        "TimeoutSeconds": 30,
        // Temperature 1.0 = standard sampling for main-loop responses.
        // The scope classifier always overrides to 0.0 for its dedicated call.
        // Lower (0.2–0.5) for more focused, concise answers.
        // Valid range for Anthropic: 0.0–1.0.
        "Temperature":    1.0
      },

      // ── OpenAI ────────────────────────────────────────────────────────────
      // gpt-4o: strong tool-use accuracy, used as fallback to Anthropic.
      // Pricing: ~$2.50 / $10 per 1 M input / output tokens.
      "openai": {
        "Model":          "gpt-4o",
        "ApiKeyEnvVar":   "OPENAI_API_KEY",
        "MaxTokens":      2048,
        "TimeoutSeconds": 30,
        // Valid range for OpenAI: 0.0–2.0. Lower values produce more focused responses.
        "Temperature":    1.0
      },

      // ── Ollama (local / self-hosted) ──────────────────────────────────────
      // Zero API cost. Suitable for data-residency requirements or air-gapped
      // deployments. BaseUrl points to the Ollama server's REST endpoint.
      // Pull model: ollama pull llama3.1:8b
      "ollama": {
        "BaseUrl":        "http://localhost:11434",
        // llama3.1:8b: best-supported model for OpenAI-compatible tool use in Ollama.
        // For higher tool-call accuracy: qwen2.5:7b (requires: ollama pull qwen2.5:7b)
        "Model":          "llama3.1:8b",
        "MaxTokens":      2048,
        // 120 s: local inference cold-start can be slow; generous timeout prevents
        // premature failures on first request after model load.
        "TimeoutSeconds": 120,
        "Temperature":    1.0
      }
    }
  },

  "AllowedHosts": "*"
}
