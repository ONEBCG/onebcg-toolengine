{
  "Database": {
    "Provider": "sqlite",
    "ConnectionString": "Data Source=toolengine.db"
  },
  "Cache": {
    "Provider": "memory"
  },
  "LLM": {
    "Provider": "claude",
    "Streaming": true,
    "Claude": {
      "ApiKey": "API KEY HERE"
    }
  },
  "Jwt": {
    "SecretKey": "dev-only-secret-key-min-32-bytes-long-replace-in-prod"
  },
  "Logging": {
    "LogLevel": {
      "Default":                                          "Debug",
      "Microsoft.AspNetCore":                             "Information",
      "Microsoft.EntityFrameworkCore.Database.Command":   "Information"
    }
  }
}
